<Page x:Class="SpolecenskaDeskovaHraSUkoly.Views.TaskDatabasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SpolecenskaDeskovaHraSUkoly.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#F0F2F5"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      Title="TaskDatabasePage">
    <Page.Resources>
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
            <Setter Property="VerticalAlignment" Value="Center" />

            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected,
            RelativeSource={RelativeSource Self}}"
                   Value="True" />
                        <Condition Binding="{Binding SelectionUnit,
            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                   Value="Cell" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#5C7A99" />
                    <Setter Property="Foreground" Value="White" />
                </MultiDataTrigger>

                <Trigger Property="IsEditing" Value="True">
                    <Setter Property="Background" Value="White" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#DADADA" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected,
                    RelativeSource={RelativeSource Self}}"
                           Value="True" />
                        <Condition Binding="{Binding (ItemsControl.AlternationIndex),
                    RelativeSource={RelativeSource Self}}" Value="0" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#5C7A99" />
                    <Setter Property="Foreground" Value="White" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected,
                    RelativeSource={RelativeSource Self}}"
                           Value="True" />
                        <Condition Binding="{Binding (ItemsControl.AlternationIndex),
                    RelativeSource={RelativeSource Self}}" Value="1" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#4A627A" />
                    <Setter Property="Foreground" Value="White" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
    Color="Transparent"/>
                <SolidColorBrush x:Key="{x:Static
    SystemColors.InactiveSelectionHighlightBrushKey}"
    Color="Transparent"/>
            </Style.Resources>

            <Setter Property="ColumnHeaderStyle" Value="{StaticResource HeaderStyle}" />
            <Setter Property="CellStyle" Value="{StaticResource CellStyle}" />
            <Setter Property="RowStyle" Value="{StaticResource RowStyle}" />

            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />

            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />

            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="GridLinesVisibility" Value="None" />

            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />

            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid Margin="60,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Databáze úkolů" Grid.Row="0" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>

            <Border Grid.Row="1" Style="{StaticResource BorderStyle}" Padding="10" Margin="0,20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Typ: " Width="80" FontSize="16" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FilterComboBox" Width="120" Height="30" FontSize="16" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                  Padding="5,0" SelectionChanged="FilterChanged"/>
                        <TextBlock Text="Hledat: " Width="60" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBox x:Name="SearchTextBox" Width="240" Height="30" FontSize="16" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                 Padding="5,0" Background="White" BorderBrush="#3A3A3A" BorderThickness="1" TextChanged="FilterChanged"/>

                        <Border Style="{StaticResource BorderStyle}" Height="30" Width="100" Margin="15,0,0,0">
                            <Button Content="Zrušit filtry" Style="{StaticResource ButtonStyle}" FontSize="14" Click="ClearFilters_Click"/>
                        </Border>
                    </StackPanel>

                    <DataGrid x:Name="TasksDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" SelectionChanged="TasksDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header=" ID" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Typ úkolu" Binding="{Binding Type}" Width="190"/>
                            <DataGridTextColumn Header="Popis" Binding="{Binding Text}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <DockPanel Grid.Row="2">
                <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" DockPanel.Dock="Left">
                    <Button Content="Zpět" Style="{StaticResource ButtonStyle}" Click="BackBtn_Click"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Margin="0,0,10,0">
                        <Button x:Name="AddTaskBtn" Content="Přidat úkol" Style="{StaticResource ButtonStyle}" Click="AddTaskBtn_Click"/>
                    </Border>
                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Margin="0,0,10,0">
                        <Button x:Name="EditTaskBtn" Content="Upravit úkol" Style="{StaticResource ButtonStyle}" Click="EditTaskBtn_Click"/>
                    </Border>
                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60">
                        <Button x:Name="DeleteTaskBtn" Content="Smazat úkol" Style="{StaticResource ButtonStyle}" Click="DeleteTaskBtn_Click"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Grid>

        <Grid x:Name="Overlay" Background="#88000000" Visibility="Collapsed">
            <Border x:Name="OverlayBorder" Style="{StaticResource BorderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <StackPanel x:Name="OverlayContent"/>
            </Border>
        </Grid>
    </Grid>
</Page>