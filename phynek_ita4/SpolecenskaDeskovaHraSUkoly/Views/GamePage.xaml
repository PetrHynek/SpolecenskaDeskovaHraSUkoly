<Page x:Class="SpolecenskaDeskovaHraSUkoly.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SpolecenskaDeskovaHraSUkoly.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#F0F2F5"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      Title="GamePage">

    <Grid>
        <Grid Margin="60,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="BoardContainer" Grid.Column="0" Grid.Row="0" Style="{StaticResource BorderStyle}" Margin="10" Padding="20">
                <Grid>
                    <Grid x:Name="BoardGrid" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource BorderStyle}" Margin="10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Stav hry" HorizontalAlignment="Center" FontSize="26" FontWeight="Bold" Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PlayersListBox" VerticalAlignment="Center" HorizontalAlignment="Center" Background="Transparent" />
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="10" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Style="{StaticResource BorderStyle}" Grid.Column="0" Height="120" Margin="0,0,40,0">
                            <Button x:Name="BtnRoll" Style="{StaticResource ButtonStyle}" Click="ButtonDiceRoll_Click" Cursor="Hand">
                                <StackPanel Margin="10">
                                    <TextBlock Text="🎲" FontSize="36" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Text="HODIT KOSTKOU" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <TextBlock x:Name="TxtDiceResult" Grid.Column="1" Width="70" Text="-" FontSize="80" VerticalAlignment="Center" TextAlignment="Center" FontWeight="Black"/>
                    </StackPanel>


                </Grid>
            </Border>


            <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Grid.Row="1" Grid.Column="0" Margin="10,0,0,0" HorizontalAlignment="Left">
                <Button x:Name="BackBtn" Content="Zpět do menu" Style="{StaticResource ButtonStyle}" Click="BackBtn_Click"/>
            </Border>
            <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Grid.Row="1" Grid.Column="1" Margin="0,0,10,0" HorizontalAlignment="Right">
                <Button x:Name="SaveBtn" Content="Uložit hru" Style="{StaticResource ButtonStyle}" Click="SaveBtn_Click"/>
            </Border>

        </Grid>

        <Grid x:Name="Overlay" Background="#88000000" Visibility="Collapsed">
            <Border x:Name="OverlayBorder" Style="{StaticResource BorderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid x:Name="OverlayContent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </Border>
        </Grid>
    </Grid>
</Page>
