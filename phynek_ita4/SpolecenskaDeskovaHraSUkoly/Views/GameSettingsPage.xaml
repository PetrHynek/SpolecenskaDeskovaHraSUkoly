<Page x:Class="SpolecenskaDeskovaHraSUkoly.Views.GameSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SpolecenskaDeskovaHraSUkoly.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#F0F2F5"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      Title="GameSettingsPage">

    <Grid>
        <Grid Margin="60,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Nastavení nové hry" Grid.Row="0" Grid.Column="1" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource BorderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,20,5,20" Padding="35,0">
                    <StackPanel>
                        <TextBlock Text="Hráči" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="Počet hráčů:" VerticalAlignment="Center" FontSize="16" Margin="0,0,15,0"/>
                            <ComboBox x:Name="ComboBoxPlayerCount" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14" Width="70" Height="35">
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="6"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel x:Name="PlayersContainer" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <Separator Margin="0,10,0,25" Background="#DDD"/>

                        <TextBlock Text="Hrací plocha" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Typ hrací desky:" Grid.Column="0" VerticalAlignment="Center" FontSize="16"/>
                            <ComboBox x:Name="ComboBoxBoardType" Grid.Column="1" FontSize="14" Width="140" Height="32" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Čtverec (Square)"/>
                                <ComboBoxItem Content="Had (Snake)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Velikost desky:" Grid.Column="0" VerticalAlignment="Center" FontSize="16"/>
                            <ComboBox x:Name="ComboBoxBoardSize" Grid.Column="1" FontSize="14" Width="140" Height="32" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Malá (6x6)"/>
                                <ComboBoxItem Content="Střední (8x8)"/>
                                <ComboBoxItem Content="Velká (10x10)"/>
                            </ComboBox>
                        </Grid>

                        <Separator Margin="0,10,0,25" Background="#DDD"/>

                        <TextBlock Text="Obsah hrací plochy" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <StackPanel Margin="40,0,0,10" HorizontalAlignment="Center" Width="180">
                            <CheckBox x:Name="CheckBonus" Content="Bonusová políčka" VerticalContentAlignment="Center" Margin="0,0,0,10" FontSize="16"/>
                            <CheckBox x:Name="CheckPenalty" Content="Trestná políčka" VerticalContentAlignment="Center" Margin="0,0,0,10" FontSize="16"/>
                            <CheckBox x:Name="CheckEmpty" Content="Prázdná políčka" VerticalContentAlignment="Center" Margin="0,0,0,10" FontSize="16"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,25" Background="#DDD"/>

                        <TextBlock Text="Nastavení hry" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Cílové skóre:" Grid.Column="0" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox x:Name="TargetScoreTextBox" Grid.Column="1" Width="80" Height="32" FontSize="14"
                                     PreviewTextInput="TextBox_PreviewTextInput" DataObject.Pasting="TextBox_Pasting"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Čas na úkol (sekundy):" Grid.Column="0" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox x:Name="TaskTimerTextBox" Grid.Column="1" Width="80" Height="32" FontSize="14"
                                     PreviewTextInput="TextBox_PreviewTextInput" DataObject.Pasting="TextBox_Pasting"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Margin="0,30,0,10" HorizontalAlignment="Center">
                            <Button x:Name="StartBtn" Content="SPUSTIT HRU" Style="{StaticResource ButtonStyle}" ToolTip="Kliknutím spustíte hru" Click="StartBtn_Click"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Grid.Row="2" HorizontalAlignment="Left">
                <Button Content="Zpět" Style="{StaticResource ButtonStyle}" Click="BackBtn_Click"/>
            </Border>
        </Grid>
    </Grid>
</Page>