<Page x:Class="SpolecenskaDeskovaHraSUkoly.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SpolecenskaDeskovaHraSUkoly.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#F0F2F5"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      Title="MainMenuPage">

    <Grid>
        <Grid Margin="60,30" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Společenská desková hra s úkoly" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <StackPanel Grid.Row="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Margin="0,0,15,0">
                        <Button Content="Nová hra" Style="{StaticResource ButtonStyle}" Click="StartGameBtn_Click"/>
                    </Border>

                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60">
                        <Button Content="Načíst rozehranou hru" Style="{StaticResource ButtonStyle}" Click="OpenGameBtn_Click"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60" Margin="0,0,15,0">
                        <Button Content="Databáze úkolů" Style="{StaticResource ButtonStyle}" Click="DatabaseBtn_Click"/>
                    </Border>

                    <Border Style="{StaticResource BorderStyle}" Width="180" Height="60">
                        <Button Content="Pravidla hry" Style="{StaticResource ButtonStyle}" Click="RulesBtn_Click"/>
                    </Border>
                </StackPanel>

                <Border Style="{StaticResource BorderStyle}" Width="240" Height="60">
                    <Button Content="Konec" Style="{StaticResource ButtonStyle}" Click="ExitBtn_Click"/>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</Page>